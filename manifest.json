{
  "manifest_version": 3,
  "name": "md telescribe",
  "version": "1.4.0",
  "description": "Record telemedicine visits and generate AI-powered SOAP notes with md telescribe.",
  "permissions": [
    "tabCapture",
    "activeTab",
    "scripting",
    "storage",
    "offscreen",
    "downloads",
    "tabs"
  ],
  "host_permissions": [
    "https://huggingface.co/*",
    "https://cdn.jsdelivr.net/*",
    "https://api.mdtelescribe.com/*",
    "https://mdtelescribe.com/*",
    "http://localhost:5000/*",
    "http://localhost:3000/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
